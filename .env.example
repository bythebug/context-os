# Database (Docker Compose maps host port 5433 → container 5432)
DATABASE_URL=postgresql+asyncpg://contextos:contextos@localhost:5433/contextos
REDIS_URL=redis://localhost:6379

# Extraction provider: anthropic | openai | mock
# Use mock for local dev without API keys
EXTRACTION_PROVIDER=mock
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Extraction model (used when EXTRACTION_PROVIDER=anthropic or openai)
ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-5-20251001
OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# Embedding provider: local | openai
# local = sentence-transformers all-MiniLM-L6-v2 (384-dim, no API key needed)
# openai = text-embedding-3-small (1536-dim, requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Admin API — protects /admin/* endpoints
# Leave empty to disable the admin API entirely
ADMIN_API_KEY=

# App server
API_HOST=0.0.0.0
API_PORT=8000
